#!/bin/sh
  set -euo pipefail

  FN=$(echo "${1}" | tr '[:upper:]' '[:lower:]')
  shift

  case "${FN}" in
    "chown")
      TARGET_UID=${2}
      TARGET_GID=${3}

      for VOLUME in ${1%/}/*/; do
        VOLUME=${VOLUME%/}
        [ -d "${VOLUME}" ] || continue
        CURRENT_UID=$(stat -c '%u' "${VOLUME}")
        CURRENT_GID=$(stat -c '%g' "${VOLUME}")
        if [ "$CURRENT_UID" = "${TARGET_UID}" ] && [ "$CURRENT_GID" = "${TARGET_GID}" ]; then
          eleven log info "${VOLUME} already correct ($CURRENT_UID:$CURRENT_GID), skipping"
        else
          eleven log info "fixing ${VOLUME}: $CURRENT_UID:$CURRENT_GID -> ${TARGET_UID}:${TARGET_GID}"
          chown -R ${TARGET_UID}:${TARGET_GID} ${VOLUME}
          chmod 0750 -R ${VOLUME}
        fi
        if [ -d "${VOLUME}/lost+found" ]; then
          eleven log info "removing ${VOLUME}/lost+found"
          rm -rf "${VOLUME}/lost+found"
        fi
      done
    ;;

    "wait")
      WHAT=$(echo "${1}" | tr '[:upper:]' '[:lower:]')
      shift
      case "${WHAT}" in
        "postgres")
          PORT="${2:-5432}"
          USER="${3:-postgres}"
          TIMEOUT="${4:-60}"
          START=$(date +%s)
          until pg_isready -h ${1} -p ${PORT} -U ${USER}; do
            NOW=$(date +%s)
            ELAPSED=$((NOW - START))
            if [ "${ELAPSED}" -ge "${TIMEOUT}" ]; then
              eleven log error "timed out after ${TIMEOUT}s waiting for ${1}:${PORT} to be ready!"
              exit 1
            fi
            eleven log info "waiting for ${1}:${PORT} to be ready..."
            sleep 2
          done
        ;;

        *)
          eleven log warning "function ${FN} does not exist"
          exit 1
        ;;
      esac
    ;;

    "help")
      echo "eleven k8s:"
      echo "  chown FOLDER UID GID"
      echo "  wait postgres HOST [PORT] [USER] [TIMEOUT]"
    ;;

    *)
      eleven log warning "function ${FN} does not exist"
      exit 1
    ;;
  esac